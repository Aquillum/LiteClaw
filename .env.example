# LLM Config
LLM_PROVIDER=openai
LLM_API_KEY=sk-xxxx
LLM_MODEL=google/gemini-3-flash-preview
LLM_BASE_URL=https://openrouter.ai/api/v1

# AWS Bedrock (API key auth)
# To use Bedrock, run `liteclaw onboard` and select "AWS Bedrock".
# The wizard will store your Bedrock API key and region in config.json.
# Optionally, you can set region here to override:
# AWS_REGION_NAME=us-east-1

# Multi-Channel Support
TELEGRAM_BOT_TOKEN=
GIPHY_API_KEY=

# Slack Config
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# WhatsApp Config
WHATSAPP_ALLOWED_NUMBERS=["your_number_here"]
WHATSAPP_TYPE=node_bridge
